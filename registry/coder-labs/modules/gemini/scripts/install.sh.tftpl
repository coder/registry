function setup_workdir() {
  if [ -n "$${ARG_WORKDIR}" ] && [ ! -d "$${ARG_WORKDIR}" ]; then
    echo "Creating workdir: $${ARG_WORKDIR}"
    mkdir -p "$${ARG_WORKDIR}"
  fi
}

install_gemini
setup_mcp_configurations
# populate_settings_json
# patch_coder_mcp_command
setup_workdir
